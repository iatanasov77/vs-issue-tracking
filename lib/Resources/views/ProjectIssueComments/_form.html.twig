<div id="FormContainer" data-itemId="{{ item.id }}">
    
    {% if useFormMethod is not defined %}
        {% set useFormMethod = item.id ? 'PUT' : 'POST' %}
    {% endif %}
    {% if useFormMethod is defined %}{% set formMethod = useFormMethod %}{% else %}{% set formMethod = 'PUT' %}{% endif %}
    
    {{ form_start(form, { 'attr': {
        'class': 'form-horizontal',
        'id': 'ProjectIssueCommentForm'
    }, 'method': formMethod }) }}
        
        {{ form_widget(form.redirectUrl) }}
        
        <div class="form-group">
            {{ form_label(form.message, null, {
                'label_attr': {'class': 'form-label'}
                }) 
            }}
            {{ form_widget(form.message, {'attr': {'class': 'form-control'}}) }}
        </div>
    {{ form_end(form, {'render_rest': false}) }}
    
</div>

{% if isAjaxRequest is defined and isAjaxRequest and useCkEditor == 5 %}
    {{ encore_entry_script_tags( 'ckeditor5' ) }}
{% endif %}
